// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Location {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  area          String
  zone          String
  phone         String
  phoneRaw      String
  address       String
  mapUrl        String
  mapEmbed      String
  lat           Float
  lng           Float
  hours         String   // Storing JSON string or simple text for hours
  image         String
  galleryImages String   // Storing JSON string array
  specialties   String   // Storing JSON string array
  features      String   // Storing JSON string array
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  description String
  price       String
  image       String
  category    String
  badge       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Offer {
  id        String   @id @default(cuid())
  text      String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
